{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/apps/trainer/index.html"
    },
    {
      "src": "^/trainer$",
      "dest": "/apps/trainer/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/apps/trainer/index.html"
    }
  ]
}
